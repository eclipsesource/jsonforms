{
  "name": "@jsonforms/react",
  "version": "4.0.0-alpha.0",
  "description": "React bindings for the JSON Forms presentation model",
  "license": "MIT",
  "type": "module",
  "homepage": "https://jsonforms.io",
  "bugs": "https://github.com/eclipsesource/jsonforms/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eclipsesource/jsonforms.git",
    "directory": "packages/react"
  },
  "keywords": [
    "form",
    "forms",
    "json",
    "json-schema",
    "react"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@jsonforms/core": "workspace:^",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@jsonforms/core": "workspace:*",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "publishConfig": {
    "access": "public"
  }
}

{
  "name": "@jsonforms/validator-ajv",
  "version": "4.0.0-alpha.0",
  "description": "AJV-backed FormValidator for JSON Forms",
  "license": "MIT",
  "type": "module",
  "homepage": "https://jsonforms.io",
  "bugs": "https://github.com/eclipsesource/jsonforms/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eclipsesource/jsonforms.git",
    "directory": "packages/validator-ajv"
  },
  "keywords": [
    "form",
    "forms",
    "json",
    "json-schema",
    "ajv",
    "validation"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1"
  },
  "peerDependencies": {
    "@jsonforms/core": "workspace:^"
  },
  "devDependencies": {
    "@jsonforms/core": "workspace:*",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
